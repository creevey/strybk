{
  "name": "strybk",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.6.0",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": "./dist/src/cli.js",
  "exports": {
    ".": "./dist/src/index.js",
    "./config": "./dist/src/config.js",
    "./playwright": "./dist/src/playwright/index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "prepack": "yarn build",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.59.0"
  },
  "dependencies": {
    "glob": "^11.0.3"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.9.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
